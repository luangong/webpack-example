
@startuml

!include config.uml

class Hook {
  - _args
  - taps
  - interceptors
  - _call
  - _promise
  - _callAsync
  - _x
  - _resetCompilation()
  - _insert()
  ..
  + compile()
  + getTapType()
  + createCall()
  + createCompileDelegate()
  + tap()
  + tapAsync()
  + tapPromise()
  + withOptions()
  + isUsed()
  + intercept()
}

class SyncBailHook {
  + tapAsync()
  + tapPromise()
  + template()
}

class Tapable {
  - _pluginCompat : SyncBailHook
  + {static} addCompatLayer()
  + plugin()
  + apply()
}

class Compiler {
  + watch()
  + run()
  + runAsChild()
  + purgeInputFileSystem()
  + emitAssets()
  + emitRecords()
  + readRecords()
  + createChildCompiler()
  + isChild()
  + createCompilation()
  + newCompilation()
  + createNormalModuleFactory()
  + createContextModuleFactory()
  + newCompilationParams()
  + compile()
}

class Template {
  + {static} getFunctionContent()
  + {static} toIdentifier()
  + {static} toPath()
  + {static} numberToIdentifier()
  ..
  + indent()
  + prefix()
  + asString()
  + getModulesArrayBounds()
  + renderChunkModules()
}

class MainTemplate {
  + render()
  + renderRequireFunctionForModule()
  + renderAddModule()
  + renderCurrentHashCode()
  + entryPointInChildren()
  + getPublicPath()
  + updateHash()
  + updateHashForChunk()
  + useChunkHash()
}

Hook <|-- SyncBailHook
Tapable <|-- Compiler
Tapable <|-- " Compilation "
Tapable <|-- Template
Template <|-- MainTemplate

@enduml

@startuml

!include config.uml

class Source {
  + source()
  + size()
  + node()
  + listNode()
  + updateHash()
  ..
  + map()
  + sourceAndMap()
}

' class " SourceAndMapMixin " {
'   + map()
'   + sourceAndMap()
' }

class ConcatSource {
  + children
  --
  + add()
  ..
  + source()
  + size()
  + node()
  + listMap()
  + updateHash()
  ..
  + map()
  + sourceAndMap()
}

class OriginalSource {
  - _value
  - _name
  --
  + source()
  + node()
  + listMap()
  + updateHash()
  ..
  + map()
  + sourceAndMap()
}

class PrefixSource {
  - _source
  - _prefix
  --
  + source()
  + node()
  + listMap()
  + updateHash()
  ..
  + map()
  + sourceAndMap()
}

Source <|-- ConcatSource
Source <|-- OriginalSource
Source <|-- PrefixSource
' " SourceAndMapMixin " o-- ConcatSource
' " SourceAndMapMixin " o-- OriginalSource
' " SourceAndMapMixin " o-- PrefixSource

@enduml

@startuml

!include config.uml

class Module {
  + context
  + reasons
  + debugId
  + id
  + portableId
  + index
  + index2
  + depth
  + used
  + usedExports
  + providedExports
  - _chunks
  - _chunksDebugIdent
  + warnings
  + dependenciesWarnings
  + errors
  + dependenciesErrors
  + strict
  + meta
  + optimizationBailout
  ..
  + entry
  + chunks
  --
  + disconnect()
  + unseal()
  + setChunks()
  + addChunk()
  + removeChunk()
  + isInChunk()
  + getChunkIdsIdent()
  + forEachChunk()
  + mapChunks()
  + getNumberOfChunks()
  + hasEqualsChunks()
  + addReason()
  + removeReason()
  + hasReasonForChunk()
  + rewriteChunkInReasons()
  + isUsed()
  + isProvided()
  + toString()
  + needRebuild()
  + updateHash()
  + sortItems()
  ..
  + identifier()
  + readableIdentifier()
  + build()
  + source()
  + size()
  + nameForCondition()
}

class Chunk {
  + id
  + ids
  + debugId
  + name
  - _modules
  + entrypoints
  + chunks
  + parents
  + blocks
  + origins
  + files
  + rendered
  ..
  + entry
  + initial
  + modulesIterable
  + modules
  --
  + hasRuntime()
  + isInitial()
  + hasEntryModule()
  + addToCollection()
  ..
  + addChunk()
  + removeChunk()
  + replaceChunk()
  + getChunkMaps()
  ..
  + addModule()
  + removeModule()
  + setModules()
  + getNumberOfModules()
  + forEachModule()
  + mapModules()
  + containsModule()
  + getModules()
  + moveModule()
  + sortModules()
  ..
  + addParent()
  + removeParent()
  + replaceParentChunk()
  ..
  + integrate()
  + canBeIntegrated()
  + integratedSize()
  ..
  + addBlock()
  + addOrigin()
  + compareTo()
  + getModulesIdent()
  + remove()
  + split()
  + isEmpty()
  + updateHash()
  + addMultiplierAndOverhead()
  + moduleSize()
  + size()
  + sortItems()
  + toString()
  + checkConstraints()
}

class Entrypoint {
  + name
  + chunks
  + unshiftChunk()
  + insertChunk()
  + getFiles()
}

@enduml
