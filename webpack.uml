
@startuml

!include config.uml

class Hook {
  - _args
  - taps
  - interceptors
  - _call
  - _promise
  - _callAsync
  - _x
  - _resetCompilation()
  - _insert()
  ..
  + compile()
  + getTapType()
  + createCall()
  + createCompileDelegate()
  + tap()
  + tapAsync()
  + tapPromise()
  + withOptions()
  + isUsed()
  + intercept()
}

class SyncBailHook {
  + tapAsync()
  + tapPromise()
  + template()
}

class Tapable {
  - _pluginCompat : SyncBailHook
  + {static} addCompatLayer()
  + plugin()
  + apply()
}

class Compiler {
  + watch()
  + run()
  + runAsChild()
  + purgeInputFileSystem()
  + emitAssets()
  + emitRecords()
  + readRecords()
  + createChildCompiler()
  + isChild()
  + createCompilation()
  + newCompilation()
  + createNormalModuleFactory()
  + createContextModuleFactory()
  + newCompilationParams()
  + compile()
}

class Template {
  + {static} getFunctionContent()
  + {static} toIdentifier()
  + {static} toPath()
  + {static} numberToIdentifier()
  ..
  + indent()
  + prefix()
  + asString()
  + getModulesArrayBounds()
  + renderChunkModules()
}

class MainTemplate {
  + render()
  + renderRequireFunctionForModule()
  + renderAddModule()
  + renderCurrentHashCode()
  + entryPointInChildren()
  + getPublicPath()
  + updateHash()
  + updateHashForChunk()
  + useChunkHash()
}

Hook <|-- SyncBailHook
Tapable <|-- Compiler
Tapable <|-- Compilation
Tapable <|-- Template
Template <|-- MainTemplate

@enduml

@startuml

!include config.uml

class Compilation {
  + compiler
  + resolvers
  + inputFileSystem
  + outputOptions
  + bail
  + profile
  + performance
  ..
  + mainTemplate
  + chunkTemplate
  + hotUpdateChunkTemplate
  + moduleTemplate
  ..
  + semaphore
  + entries
  + preparedChunks
  + entryPoints
  + chunks
  + namedChunks
  + modules
  + modules
  - _modules
  + cache
  + records
  + nextFreeModuleIndex
  + nextFreeModuleIndex2
  + additionalChunkAssets
  + assets
  + error
  + warnings
  + children
  + dependencyFactories
  + dependencyTemplates
  + childrenCounters
  --
  + getStats()
  + templatesPlugin()
  ..
  + addModule()
  + buildModule()
  + rebuildModule()
  + findModule()
  + getModule()
  + sortModules()
  + addModuleDependencies()
  + processModuleDependencies()
  + sortItemsWithModuleIds()
  + applyModuleIds()
  + createModuleAssets()
  ..
  + addChunk()
  + processDependenciesBlocksForChunks()
  + removeChunkFromDependencies()
  + applyChunkIds()
  + sortItemsWithChunkIds()
  + createChunkAssets()
  ..
  - _addModuleChain()
  + addEntry()
  + prefetch()
  + finish()
  + seal()
  + unseal()
  + reportDependencyErrorsAndWarnings()
  + assignIndex()
  + assignDepth()
  + summarizeDependencies()
  ..
  + createHash()
  + modifyHash()
  ..
  + getPath()
  + createChildCompiler()
  + checkConstraints()
}

@enduml
