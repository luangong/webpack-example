@startuml

hide circle
hide empty members
skinparam defaultFontName "Inconsolata"
skinparam defaultFontSize 12

class Hook {
  - _args
  - taps
  - interceptors
  - _call
  - _promise
  - _callAsync
  - _x
  - _resetCompilation()
  - _insert()
  ..
  + compile()
  + getTapType()
  + createCall()
  + createCompileDelegate()
  + tap()
  + tapAsync()
  + tapPromise()
  + withOptions()
  + isUsed()
  + intercept()
}

class SyncBailHook {
  + tapAsync()
  + tapPromise()
  + template()
}

class Tapable {
  - _pluginCompat : SyncBailHook
  + {static} addCompatLayer()
  + plugin()
  + apply()
}

class Template {
  + {static} getFunctionContent()
  + {static} toIdentifier()
  + {static} toPath()
  + {static} numberToIdentifier()
  ..
  + indent()
  + prefix()
  + asString()
  + getModulesArrayBounds()
  + renderChunkModules()
}

class MainTemplate {
  + render()
  + renderRequireFunctionForModule()
  + renderAddModule()
  + renderCurrentHashCode()
  + entryPointInChildren()
  + getPublicPath()
  + updateHash()
  + updateHashForChunk()
  + useChunkHash()
}

Hook <|-- SyncBailHook
Tapable <|-- Template
Template <|-- MainTemplate

@enduml
